                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">{&#xd;
    &quot;mobile_number&quot;: &quot;${MOBILE_NUMBER}&quot;,&#xd;
    &quot;otp&quot;: &quot;${OTP}&quot;,&#xd;
    &quot;device_token&quot;: &quot;${DEVICE_TOKEN}&quot;,&#xd;
    &quot;latitude&quot;: &quot;18.1471348000&quot;,&#xd;
    &quot;longitude&quot;: &quot;74.5809889000&quot;,&#xd;
    &quot;is_signup&quot;: false&#xd;
